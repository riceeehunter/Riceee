generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  clerkUserId    String         @unique
  email          String         @unique
  name           String?
  imageUrl       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  partnerOneName String?
  partnerTwoName String?
  collections    Collection[]
  comments       Comment[]
  currentDraft   Draft?
  entries        Entry[]
  memories       Memory[]
  messages       Message[]
  spaceInvites   SpaceInvite[]
  identities     UserIdentity[]
  conversations  ChatConversation[]
  courtroomCases CourtroomCase[]
}

model ChatConversation {
  id        String     @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cells     ChatCell[]

  @@index([userId])
}

model ChatCell {
  id             String           @id @default(cuid())
  conversationId String
  content        String           @db.Text
  response       String?          @db.Text
  order          Int
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model CourtroomCase {
  id               String     @id @default(cuid())
  userId           String
  title            String
  status           CaseStatus @default(OPEN)
  sideAPerspective String?    @db.Text
  sideBPerspective String?    @db.Text
  sideAAuthor      String?
  sideBAuthor      String?
  judgement        String?    @db.Text
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum CaseStatus {
  OPEN
  PENDING
  CLOSED
}

model UserIdentity {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  userId      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SpaceInvite {
  id                String       @id @default(cuid())
  token             String       @unique
  userId            String
  status            InviteStatus @default(PENDING)
  expiresAt         DateTime
  acceptedAt        DateTime?
  acceptedByClerkId String?
  createdByClerkId  String
  createdAt         DateTime     @default(now())
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     Entry[]

  @@unique([name, userId])
}

model Entry {
  id           String      @id @default(cuid())
  title        String
  content      String
  mood         String
  moodScore    Int
  moodImageUrl String?
  author       String      @default("Both Partners")
  collectionId String?
  userId       String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  comments     Comment[]
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Draft {
  id        String   @id @default(cuid())
  title     String?
  content   String?
  mood      String?
  author    String?  @default("Both Partners")
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Comment {
  id            String         @id @default(cuid())
  content       String
  author        String
  entryId       String
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  entry         Entry          @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Notification[]
}

model Notification {
  id            String   @id @default(cuid())
  type          String
  message       String
  entryId       String?
  entryTitle    String?
  caseId        String?
  commentId     String?
  commentAuthor String?
  hunterRead    Boolean  @default(false)
  riceeeRead    Boolean  @default(false)
  createdAt     DateTime @default(now())
  comment       Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Message {
  id             String   @id @default(cuid())
  content        String
  sender         String
  userId         String
  read           Boolean  @default(false)
  replyTo        String?
  replyToContent String?
  replyToSender  String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Memory {
  id         String   @id @default(cuid())
  url        String
  key        String
  caption    String?
  uploadedBy String
  userId     String
  fileSize   Int
  mimeType   String
  width      Int?
  height     Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}
